# ──────────────────────────────────────────────────────────────────────────────
# Cloud Cost Optimizer — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real credentials.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── NVIDIA NIM / OpenAI API ─────────────────────────────────────────────────
# For NVIDIA NIM (recommended — free tier available):
#   1. Sign up at https://build.nvidia.com
#   2. Generate an API key (starts with "nvapi-")
#   3. Paste it below
OPENAI_API_KEY=nvapi-YOUR_KEY_HERE

# NVIDIA NIM Base URL (OpenAI-compatible endpoint)
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Alternative: OpenAI Direct ──────────────────────────────────────────────
# Uncomment these and comment out the NVIDIA lines above to use OpenAI directly:
# OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Ingress API (Optional — for production bridge) ─────────────────────────
# INGRESS_API_KEY=your-secret-ingress-key
# INGRESS_HOST=0.0.0.0
# INGRESS_PORT=8000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
